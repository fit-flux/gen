{
  "name": "fitflux",
  "version": "1.0.0",
  "description": "FitFlux AI coordinate generation project configuration",
  "project": {
    "language": "javascript",
    "framework": "cloudflare-pages-static",
    "frontend": "html-tailwind-vanilla-js",
    "image_generator": "gemini",
    "primary_model": "gemini-2.5-flash-image"
  },
  "tools": {
    "preferred_shell": "bash",
    "package_manager": "npm",
    "type_checker": "tsc",
    "deploy_command": "npm run deploy"
  },
  "constraints": {
    "free_tier_first": true,
    "mobile_first": true
  }
}
