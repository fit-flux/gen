{
  "project": {
    "name": "FitFlux",
    "description": "AIコーディネート試着室。静的HTMLのみで構成され、あらかじめGeminiで生成した画像を静的配信します。",
    "default_language": "ja",
    "coding_assistant": "Antigravity"
  },
  "context": {
    "always_include": ["README.md", "architecture.md", "spec.md"],
    "include_on_request": ["index.html", "scripts/outfit-config.mjs", "scripts/generate-outfits.mjs"]
  },
  "commands": {
    "enabled": ["commit", "test", "fix"]
  },
  "style": {
    "minimal_changes": true,
    "match_project_conventions": true,
    "test_before_done": true
  }
}
